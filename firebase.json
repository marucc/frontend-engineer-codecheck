{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        "*.local"
      ],
      "predeploy": [
        "pnpm --filter @fec/functions run lint",
        "pnpm --filter @fec/functions run build"
      ]
    }
  ],
  "hosting": {
    "public": "hosting/dist",
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api",
        "region": "asia-northeast1"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "emulators": {
    "functions": {
      "port": 5001,
      "host": "0.0.0.0"
    },
    "hosting": {
      "port": 5000,
      "host": "0.0.0.0"
    },
    "ui": {
      "disable": false
    },
    "singleProjectMode": true
  }
}
